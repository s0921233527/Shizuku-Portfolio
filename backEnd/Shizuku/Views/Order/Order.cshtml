<!-- 引入必要的 CSS (通常建議放在 Layout 或 Head 中) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="container-fluid py-4">
    <!-- 頁面標題 -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-receipt me-2"></i>訂單管理
            <small class="text-muted fs-6">/ 訂單列表</small>
        </h2>
        <button class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-download me-2"></i>匯出訂單
        </button>
    </div>

    <!-- 狀態快速篩選卡片 (純靜態顯示) -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3 rounded-4">
                <small class="opacity-75">今日新訂單</small>
                <h3 class="fw-bold mb-0">12 筆</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark p-3 rounded-4">
                <small class="opacity-75">待出貨訂單</small>
                <h3 class="fw-bold mb-0">5 筆</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white p-3 rounded-4">
                <small class="opacity-75">異常訂單</small>
                <h3 class="fw-bold mb-0">2 筆</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white p-3 rounded-4">
                <small class="opacity-75">已完成訂單</small>
                <h3 class="fw-bold mb-0">158 筆</h3>
            </div>
        </div>
    </div>

    <!-- 訂單表格卡片 -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle w-100" id="orderTable">
                <thead class="table-light">
                    <tr>
                        <th>訂單編號</th>
                        <th>下單時間</th>
                        <th>客戶姓名</th>
                        <th>付款方式</th>
                        <th>訂單金額</th>
                        <th>狀態</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- 假資料 1 -->
                    <tr>
                        <td><code class="fw-bold text-primary">ORD-20260327-001</code></td>
                        <td class="small">2026-03-27 10:30</td>
                        <td class="fw-bold">王小明</td>
                        <td><span class="badge bg-light text-dark border rounded-pill px-3">信用卡</span></td>
                        <td class="fw-bold text-danger">NT$ 1,580</td>
                        <td>
                            <span class="badge bg-success-subtle text-success rounded-pill px-3 border border-success-subtle">已付款</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-secondary" title="查看詳情"><i class="bi bi-eye"></i></button>
                                <button class="btn btn-sm btn-outline-primary" title="編輯訂單"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" title="作廢訂單"><i class="bi bi-slash-circle"></i></button>
                            </div>
                        </td>
                    </tr>
                    <!-- 假資料 2 -->
                    <tr>
                        <td><code class="fw-bold text-primary">ORD-20260327-002</code></td>
                        <td class="small">2026-03-27 11:15</td>
                        <td class="fw-bold">李知恩</td>
                        <td><span class="badge bg-light text-dark border rounded-pill px-3">ATM 轉帳</span></td>
                        <td class="fw-bold text-danger">NT$ 2,400</td>
                        <td>
                            <span class="badge bg-warning-subtle text-warning-emphasis rounded-pill px-3 border border-warning-subtle">待付款</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-secondary" title="查看詳情"><i class="bi bi-eye"></i></button>
                                <button class="btn btn-sm btn-outline-primary" title="編輯訂單"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" title="作廢訂單"><i class="bi bi-slash-circle"></i></button>
                            </div>
                        </td>
                    </tr>
                    <!-- 假資料 3 -->
                    <tr>
                        <td><code class="fw-bold text-primary">ORD-20260327-003</code></td>
                        <td class="small">2026-03-27 11:45</td>
                        <td class="fw-bold">張曼玉</td>
                        <td><span class="badge bg-light text-dark border rounded-pill px-3">LINE Pay</span></td>
                        <td class="fw-bold text-danger">NT$ 890</td>
                        <td>
                            <span class="badge bg-info-subtle text-info rounded-pill px-3 border border-info-subtle">出貨中</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-secondary" title="查看詳情"><i class="bi bi-eye"></i></button>
                                <button class="btn btn-sm btn-outline-primary" title="編輯訂單"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" title="作廢訂單"><i class="bi bi-slash-circle"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 引入必要的 Script -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
    $(document).ready(function () {
    $('#orderTable').DataTable({
    "language": {
    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/zh-HANT.json"
    },
    "pageLength": 10,
    "order": [[1, "desc"]], // 預設下單時間倒序
    "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
    "<'row'<'col-sm-12'tr>>" +
    "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
    });
    });
</script>