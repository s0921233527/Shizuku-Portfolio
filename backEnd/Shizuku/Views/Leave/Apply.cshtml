@model Shizuku.ViewModels.LeaveViewModel
@using Shizuku.Enums
@{
    ViewData["Title"] = "請假申請系統";
}

<div class="container py-5">
    <div class="row">
        <!-- 左側：申請表單 (保持不變) -->
        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 mb-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>填寫假單</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Apply" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">員工編號</label>
                            <input type="text" asp-for="EmployeeNumber" class="form-control" placeholder="例如: EMP001" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">假別選擇</label>
                                <select asp-for="SelectedLeaveType" class="form-select">
                                    @foreach (var type in Enum.GetValues(typeof(LeaveType)))
                                    {
                                        <option value="@((int)type)">@type.ToString()</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">開始時間</label>
                                <input type="datetime-local" asp-for="StartDate" class="form-control"
                                       value="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")" required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">結束時間</label>
                                    <input type="datetime-local" asp-for="EndDate" class="form-control"
                                           value="@Model.EndDate.ToString("yyyy-MM-ddTHH:mm")" required>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 py-2 fs-5 rounded-pill shadow-sm">
                                        送出申請
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- 右側：最近紀錄清單 (套用 DataTables) -->
                    <div class="col-lg-8">
                        <div class="d-flex justify-content-between align-items-end mb-3">
                            <div>
                                <h3 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>假單管理</h3>
                                <p class="text-muted small mb-0">目前顯示：@(ViewBag.StatusFilter == "Pending" ? "待處理案件" : "歷史審核紀錄")</p>
                            </div>
        
                            <!-- 切換按鈕組 -->
                            <div class="btn-group shadow-sm">
                                <a href="@Url.Action("Apply", new { statusFilter = "Pending" })"
                                       class="btn btn-outline-primary @(ViewBag.StatusFilter == "Pending" ? "active" : "")">
                                    待審核
                                </a>
                                <a href="@Url.Action("Apply", new { statusFilter = "History" })"
                                       class="btn btn-outline-primary @(ViewBag.StatusFilter == "History" ? "active" : "")">
                                    審核紀錄
                                </a>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0 text-center w-100" id="leaveTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>姓名</th>
                                            <th>假別</th>
                                            <th>開始時間</th>
                                            <th>結束時間</th>
                                            <th>狀態</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.LeaveRecords)
                                        {
                                            <tr>
                                                <td class="fw-bold">@item.EmployeeName</td>
                                                <td>
                                                    @{
                                                        // 動態判斷假別顏色 (使用 subtle 柔和色調)
                                                        string typeClass = item.LeaveTypeName switch
                                                        {
                                                            "事假" => "badge rounded-pill bg-info text-dark",
                                                            "病假" => "badge rounded-pill bg-dark",
                                                            "特休" => "badge rounded-pill bg-light text-dark",
                                                            "公假" => "badge rounded-pill bg-primary",
                                                            _ => "badge rounded-pill bg-secondary"
                                                        };
                                                    }
                                                    <span class="badge rounded-pill px-3 border @typeClass">
                                                        @item.LeaveTypeName
                                                    </span>
                                                </td>
                                                <td class="small">@item.StartDate</td>
                                                <td class="small">@item.EndDate</td>
                                                <td>
                                                    @{
                                                        string statusClass = item.StatusName switch
                                                        {
                                                            "已核准" => "bg-success",
                                                            "駁回" => "bg-danger",
                                                            _ => "bg-warning text-dark"
                                                        };
                                                    }
                                                    <span class="badge @statusClass rounded-pill px-3">@item.StatusName</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @section Scripts {
                <!-- 引入 DataTables 資源 -->
                <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
                <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
                <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
                <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

                <script>
                    $(document).ready(function () {
                    $('#leaveTable').DataTable({
                    "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "全部"]],
                    "pageLength": 10,
                    "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/zh-HANT.json"
                    },
                    "order": [[2, "desc"]], // 預設依照「開始時間」(第3欄) 倒序排列
                    "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" + // 顯示搜尋框 (f)
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
                    });

                    // 自動關閉 Alert 訊息
                    setTimeout(function() {
                    $('.alert').alert('close');
                    }, 5000);
                    });
                </script>
            }