@model IEnumerable<Shizuku.Models.TEmployee>

@{
    ViewData["Title"] = "員工管理";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="fw-bold mb-0 text-dark">員工資料一覽表</h2>
        <small class="text-muted">檢視、篩選與管理系統內的所有員工紀錄</small>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
            + 新增員工
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    
    <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
        @using (Html.BeginForm("List", "Employee", FormMethod.Post, new { id = "searchForm" }))
        {
            <div class="row g-3 align-items-center bg-light p-3 rounded-3">
                <div class="col-auto">
                    <label class="text-muted small fw-bold mb-1">員工狀態</label>
                    <select class="form-select form-select-sm border-0 shadow-none" id="statusFilter" name="statusFilter" style="min-width: 150px;">
                        <option value="Active" selected="@(ViewBag.StatusFilter == "Active" ? "selected" : null)">僅顯示在職</option>
                        <option value="All" selected="@(ViewBag.StatusFilter == "All" ? "selected" : null)">顯示全部 (含離職)</option>
                        <option value="Resigned" selected="@(ViewBag.StatusFilter == "Resigned" ? "selected" : null)">僅顯示離職</option>
                    </select>
                </div>
                <div class="col-auto flex-grow-1">
                    <label class="text-muted small fw-bold mb-1">關鍵字搜尋</label>
                    <div class="input-group input-group-sm">
                        @Html.TextBox("txtKeyword", null, new { @class = "form-control border-0 shadow-none", placeholder = "請輸入姓名、信箱、電話等關鍵字..." })
                        <button type="submit" class="btn btn-secondary px-3">查詢</button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card-body px-4 pt-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle border-top" id="employeeTable">
                <thead class="table-light text-muted small">
                    <tr>
                        <th class="fw-normal">排序</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FNumber)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FName)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FAddress)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FEmail)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FPhone)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FHireDate)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FDepartmentId)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FPositionId)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FStatus)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FCreatedAt)</th>
                        <th class="fw-normal">@Html.DisplayNameFor(model => model.FUpdatedAt)</th>
                        <th class="fw-normal text-end">操作</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @{
                        int count = 0;
                        foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td class="text-muted">@count</td>
                                <td><span class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.FNumber)</span></td>
                                <td>@Html.DisplayFor(modelItem => item.FName)</td>
                                <td class="text-truncate" style="max-width: 150px;" title="@item.FAddress">@Html.DisplayFor(modelItem => item.FAddress)</td>
                                <td><a href="mailto:@item.FEmail" class="text-decoration-none">@Html.DisplayFor(modelItem => item.FEmail)</a></td>
                                <td>@Html.DisplayFor(modelItem => item.FPhone)</td>
                                <td>@Html.DisplayFor(modelItem => item.FHireDate)</td>
                                <td>@Html.DisplayFor(modelItem => item.FDepartmentId)</td>
                                <td>@Html.DisplayFor(modelItem => item.FPositionId)</td>
                                <td>
                                    @if (item.FStatus == "離職")
                                    {
                                        <span class="badge rounded-pill bg-danger px-3">@item.FStatus</span>
                                    }
                                    else if (item.FStatus == "在職")
                                    {
                                        <span class="badge rounded-pill bg-success px-3">@item.FStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary px-3">@item.FStatus</span>
                                    }
                                </td>
                                <td class="text-muted small">@Html.DisplayFor(modelItem => item.FCreatedAt)</td>
                                <td class="text-muted small">@Html.DisplayFor(modelItem => item.FUpdatedAt)</td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.FId" class="btn btn-sm btn-outline-primary">編輯</a>
                                        <a asp-action="Delete" asp-route-id="@item.FId" class="btn btn-sm btn-outline-danger" onclick="return confirm('確定要停用這筆資料嗎?');">停用</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" /> <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
        $('#employeeTable').DataTable({
        "lengthMenu": [[10, 20, 50, -1], [10, 20, 50, "全部"]],
        "pageLength": 10,
        "language": {
        "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/zh-HANT.json"
        },
        "columnDefs": [
        { "orderable": false, "targets": [0, 12] } // 將第一欄(序號)與最後一欄(操作)關閉排序
        ],
        "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'>>" + 
        "<'row'<'col-sm-12'tr>>" +
        "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>", // 微調 DataTables 排版使其更貼合 Bootstrap 5
        });

        // 監聽下拉選單，自動提交表單
        $('#statusFilter').change(function() {
        $('#searchForm').submit();
        });
        });
    </script>
}