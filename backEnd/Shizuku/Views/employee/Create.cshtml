@model Shizuku.Models.TEmployee

@{
    ViewData["Title"] = "Create";
}

<h1>新增員工</h1>
<h4>輸入員工資訊</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
           
            <div class="form-group mb-3">
                <label asp-for="FName" class="control-label"></label>
                <input asp-for="FName" class="form-control" />
                <span asp-validation-for="FName" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="FPhone" class="control-label"></label>
                <input asp-for="FPhone" class="form-control" />
                <span asp-validation-for="FPhone" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="FEmail" class="control-label"></label>
                <input asp-for="FEmail" class="form-control" />
                <span asp-validation-for="FEmail" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="FAddress" class="control-label"></label>
                <input asp-for="FAddress" class="form-control" />
                <span asp-validation-for="FAddress" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="FPassword" class="control-label"></label>
                <input asp-for="FPassword" class="form-control" type="password" /> <span asp-validation-for="FPassword" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FDepartmentId" class="control-label">部門</label>
                <select asp-for="FDepartmentId" class="form-control" asp-items="ViewBag.DepartmentList">
                    <option value="">-- 請選擇部門 --</option>
                </select>
                <span asp-validation-for="FDepartmentId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FPositionId" class="control-label">職位</label>
                <select asp-for="FPositionId" class="form-control" asp-items="ViewBag.PositionList">
                    <option value="">-- 請選擇職位 --</option>
                </select>
                <span asp-validation-for="FPositionId" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="送出並新增" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="List" class="btn btn-secondary">返回列表</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}