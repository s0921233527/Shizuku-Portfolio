    @* 側邊欄位不縮排 但會閃爍 *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. 取得當前網址的路徑 (例如: /Member/List)
            var currentPath = window.location.pathname;

            // 2. 遍歷所有的子選單連結
            var navLinks = document.querySelectorAll('#sidebarMenu .nav-link');

            navLinks.forEach(function (link) {
                var href = link.getAttribute('href');

                // 3. 如果連結的 href 包含在當前網址中 (排除首頁或空連結)
                if (href && href !== '#' && currentPath.includes(href)) {
                    // 4. 向上尋找最近的 .collapse 容器並展開它
                    var parentCollapse = link.closest('.collapse');
                    if (parentCollapse) {
                        parentCollapse.classList.add('show');

                        // 5. 選項：同步更新父層按鈕的 aria-expanded 狀態，避免第一次點擊失效
                        var toggleBtn = document.querySelector(`[href="#${parentCollapse.id}"]`);
                        if (toggleBtn) {
                            toggleBtn.setAttribute('aria-expanded', 'true');
                            toggleBtn.classList.remove('collapsed');
                        }

                        // 6. 選項：將當前連結標示為活躍狀態 (Active)
                        link.classList.add('active');
                    }
                }
            });
        });
    </script>
