@model IEnumerable<Shizuku.ViewModels.LogViewModel>
@{
    ViewData["Title"] = "系統日誌管理";
    var currentLevel = ViewBag.CurrentLevel as string;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-terminal me-2"></i>系統日誌 (System Logs)</h2>
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label class="form-label small fw-bold">起始時間</label>
                    <input type="datetime-local" id="startTime" class="form-control form-control-sm"
                           value="@ViewBag.StartTime">
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-bold">結束時間</label>
                    <input type="datetime-local" id="endTime" class="form-control form-control-sm"
                           value="@ViewBag.EndTime">
                </div>
                <div class="col-auto">
                    <label class="form-label small fw-bold">顯示等級</label>
                    <select class="form-select form-select-sm" id="levelFilter">
                        <option value="">-- 全部顯示 --</option>
                        <option value="Trace" selected="@(currentLevel == "Trace")">Trace</option>
                        <option value="Debug" selected="@(currentLevel == "Debug")">Debug</option>
                        <option value="Information" selected="@(currentLevel == "Information")">Information</option>
                        <option value="Warning" selected="@(currentLevel == "Warning")">Warning</option>
                        <option value="Error" selected="@(currentLevel == "Error")">Error</option>
                        <option value="Fatal" selected="@(currentLevel == "Fatal")">Fatal</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary px-3" onclick="applyFilters()">
                        <i class="fas fa-search me-1"></i>篩選
                    </button>
                    <button class="btn btn-sm btn-success px-3" onclick="exportLogs()">
                        <i class="fas fa-file-download me-1"></i>匯出 TXT
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4">時間</th>
                        <th>等級</th>
                        <th>訊息內容</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">@item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                @if (item.Level == "Trace" || item.Level == "Debug")
                                {
                                    <span class="badge rounded-pill bg-secondary">@item.Level</span>
                                }
                                else if (item.Level == "Error" || item.Level == "Fatal")
                                {
                                    <span class="badge rounded-pill bg-danger">@item.Level</span>
                                }
                                else if (item.Level == "Warning")
                                {
                                    <span class="badge rounded-pill bg-warning text-dark">@item.Level</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-info text-white">@item.Level</span>
                                }
                            </td>
                            <td class="text-truncate" style="max-width: 600px;">@item.Message</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-secondary" onclick="showLogDetail('@item.Id')">查看</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                function getFilterParams() {
            const level = document.getElementById("levelFilter").value;
            const start = document.getElementById("startTime").value; // 改 ID
            const end = document.getElementById("endTime").value;     // 改 ID
            return `level=${level}&startTime=${start}&endTime=${end}`;
        }

        function applyFilters() {
            window.location.href = "/System/Index?" + getFilterParams();
        }

        function exportLogs() {
            window.location.href = "/System/Export?" + getFilterParams();
        }
    </script>
}