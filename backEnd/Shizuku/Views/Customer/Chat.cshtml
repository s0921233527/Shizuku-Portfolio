@{
    ViewData["Title"] = "客服中心 - 真人即時對談";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-dark text-white">線上訪客列表</div>
                <ul class="list-group list-group-flush" id="guestList">
                </ul>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white" id="chatHeader">請從左側選擇訪客開始對談</div>
                <div class="card-body" style="height: 400px; overflow-y: auto;" id="chatWindow">
                </div>
                <div class="card-footer">
                    <div class="input-group">
                        <input type="hidden" id="targetGuestId" />
                        <input type="text" id="messageInput" class="form-control" placeholder="輸入回覆內容..." disabled />
                        <button class="btn btn-primary" id="sendButton" disabled>傳送</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .build();

    let activeGuests = {};

    function getCurrentTime() {
    const now = new Date();
    return now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
    }

    connection.on("ReceiveFromGuest", function (guestId, message) {
    if (!activeGuests[guestId]) {
    activeGuests[guestId] = [];
    const li = document.createElement("li");
    li.className = "list-group-item list-group-item-action d-flex justify-content-between align-items-center";
    li.style.cursor = "pointer";
    // 把亂碼包裝成比較好看的格式
    const shortId = guestId.substring(0, 5).toUpperCase();
    li.innerHTML = `匿名訪客 (${shortId}) <span class="badge bg-danger rounded-pill">新</span>`;
    li.onclick = function () {
    selectGuest(guestId, li, shortId);
    };
    document.getElementById("guestList").appendChild(li);
    }

    const timeString = getCurrentTime();
    activeGuests[guestId].push({ sender: "Guest", text: message, time: timeString });

    if (document.getElementById("targetGuestId").value === guestId) {
    appendMessage("訪客", message, "text-start", "bg-light text-dark", timeString);
    }
    });

    function selectGuest(guestId, element, shortId) {
    document.querySelectorAll("#guestList li").forEach(el => el.classList.remove("active"));
    element.classList.add("active");
        
    // 移除新訊息的紅色標籤
    const badge = element.querySelector('.badge');
    if(badge) badge.remove();
        
    document.getElementById("targetGuestId").value = guestId;
    document.getElementById("chatHeader").innerText = "與 匿名訪客 (" + shortId + ") 對談中";
    document.getElementById("messageInput").disabled = false;
    document.getElementById("sendButton").disabled = false;
        
    const chatWindow = document.getElementById("chatWindow");
    chatWindow.innerHTML = "";
    activeGuests[guestId].forEach(msg => {
    if (msg.sender === "Guest") {
    appendMessage("訪客", msg.text, "text-start", "bg-light text-dark", msg.time);
    } else {
    appendMessage("客服", msg.text, "text-end", "bg-primary text-white", msg.time);
    }
    });
    }

    function appendMessage(sender, text, alignClass, colorClass, timeString) {
    const msgDiv = document.createElement("div");
    msgDiv.className = "mb-3 " + alignClass;
        
    const timeHtml = `<small class="text-muted mx-2">${timeString}</small>`;
    const nameHtml = `<div class="small text-secondary mb-1">${sender}</div>`;
    const bubbleHtml = `<div class="d-inline-block p-2 rounded ${colorClass}" style="max-width: 75%; text-align: left;">${text}</div>`;

    if(alignClass === "text-end") {
    msgDiv.innerHTML = nameHtml + timeHtml + bubbleHtml;
    } else {
    msgDiv.innerHTML = nameHtml + bubbleHtml + timeHtml;
    }

    const chatWindow = document.getElementById("chatWindow");
    chatWindow.appendChild(msgDiv);
    chatWindow.scrollTop = chatWindow.scrollHeight;
    }

    connection.start().then(function () {
    connection.invoke("JoinAsAdmin").catch(function (err) {
    return console.error(err.toString());
    });
    }).catch(function (err) {
    return console.error(err.toString());
    });

    document.getElementById("sendButton").addEventListener("click", function (event) {
    const guestId = document.getElementById("targetGuestId").value;
    const message = document.getElementById("messageInput").value;
        
    if (!message || !guestId) return;

    connection.invoke("ReplyToGuest", guestId, message).then(function() {
    const timeString = getCurrentTime();
    activeGuests[guestId].push({ sender: "Admin", text: message, time: timeString });
    appendMessage("客服", message, "text-end", "bg-primary text-white", timeString);
    document.getElementById("messageInput").value = "";
    }).catch(function (err) {
    return console.error(err.toString());
    });
        
    event.preventDefault();
    });

    document.getElementById("messageInput").addEventListener("keypress", function (e) {
    if (e.key === 'Enter') {
    document.getElementById("sendButton").click();
    }
    });
</script>