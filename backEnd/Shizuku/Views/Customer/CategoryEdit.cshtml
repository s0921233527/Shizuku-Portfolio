@model Shizuku.Wraps.CTicketCategoryWrap

@{
    ViewData["Title"] = "編輯問題分類";
}

<h1>編輯問題分類</h1>
<hr />
<div class="row">
    <div class="col-md-5">
        <form asp-action="CategoryEdit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            @* 隱藏的主鍵 *@
            <input type="hidden" asp-for="Entity.FId" />

            <div class="form-group mb-3">
                <label asp-for="fName" class="control-label fw-bold"></label>
                <input asp-for="fName" class="form-control" placeholder="例如：商品瑕疵" />
                <span asp-validation-for="fName" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="fDescription" class="control-label fw-bold"></label>
                @* 描述通常字比較多，我們換成 textarea 讓客服比較好打字 *@
                <textarea asp-for="fDescription" class="form-control" rows="3" placeholder="請輸入分類描述..."></textarea>
                <span asp-validation-for="fDescription" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="確認存檔" class="btn btn-primary" />
                <a asp-action="Categories" class="btn btn-secondary ms-2">返回清單</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}