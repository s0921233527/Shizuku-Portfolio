@model IEnumerable<Shizuku.Wraps.CTicketCustomerWrap>

@{
	ViewData["Title"] = "List";
}

<h1>@ViewBag.TitleName</h1>

@using (Html.BeginForm())
{
	<div class="search-box p-3 bg-light rounded shadow-sm mb-3">
		<div class="row align-items-center">
			<div class="col-auto">
				<span class="fw-bold">關鍵字：</span>
				@* 這裡的名稱一定要叫 txtKeyword，對應你的 ViewModel *@
				@Html.TextBox("txtKeyword", null, new { @class = "form-control d-inline-block", style = "width:200px;", placeholder = "輸入主旨..." })
			</div>
			<div class="col-auto">
				<button type="submit" class="btn btn-dark">查詢</button>
			</div>
		</div>
	</div>
}

<p>
	<a asp-action="Create">新增案件</a>
</p>

<table class="table table-hover align-middle border-bottom">
	<thead class="table-light">
		<tr class="text-center">
			<th>序</th>
			<th>@Html.DisplayNameFor(model => model.fId)</th>
			<th>@Html.DisplayNameFor(model => model.fMemberId)</th>
			<th>@Html.DisplayNameFor(model => model.fOrderId)</th>
			<th>問題類型</th> @* 這裡手動給標題，因為是關聯欄位 *@
			<th>@Html.DisplayNameFor(model => model.fSubject)</th>
			<th>@Html.DisplayNameFor(model => model.fStatus)</th>
			<th>@Html.DisplayNameFor(model => model.fPriority)</th>
			<th>經辦客服</th>
			<th>建立時間</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@{
			int count = 0;
			foreach (var item in Model)
			{
				count++;
				<tr class="text-center">
					<td>@count</td>
					<td>@Html.DisplayFor(modelItem => item.fId)</td>
					<td>@Html.DisplayFor(modelItem => item.fMemberId)</td>
					<td>@Html.DisplayFor(modelItem => item.fOrderId)</td>
					<td>
						@* 透過 .Entity 存取導覽屬性，顯示分類名稱 *@
						<span class="fw-bold text-primary">
							@(item.Entity.FCategory != null ? item.Entity.FCategory.FName : "未分類")
						</span>
					</td>
					<td class="text-start">
						@Html.DisplayFor(modelItem => item.fSubject)
					</td>
					<td>
						@if (item.fStatus == "待處理")
						{
							<span class="badge bg-danger">@Html.DisplayFor(modelItem => item.fStatus)</span>
						}
						else if (item.fStatus == "處理中")
						{
							<span class="badge bg-warning text-dark">@Html.DisplayFor(modelItem => item.fStatus)</span>
						}
						else if (item.fStatus == "已結案")
						{
							<span class="badge bg-success">@Html.DisplayFor(modelItem => item.fStatus)</span>
						}
						else if (item.fStatus == "不予處理")
						{
							<span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.fStatus)</span>
						}
						else
						{
							<span class="badge bg-light text-dark">@Html.DisplayFor(modelItem => item.fStatus)</span>
						}
					</td>
					<td>
						<span class="@(item.fPriority == "高" ? "text-danger fw-bold" : item.fPriority == "中" ? "text-warning" : "text-secondary")">
							@Html.DisplayFor(modelItem => item.fPriority)
						</span>
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.Entity.FAssignedAgentId)
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.Entity.FCreatedAt)
					</td>
					<td>
						@Html.ActionLink("編輯", "Edit", "Customer", new { id = item.fId }, null) |
						@Html.ActionLink("刪除", "Delete", "Customer", new { id = item.fId },
								 new { onclick = "return confirm('確定要刪除嗎?')" })
					</td>
				</tr>
			}
		}
	</tbody>
</table>

<style>
	/* 7. 超連結變身按鈕 */
	.table td a {
		text-decoration: none;
		padding: 4px 10px;
		border-radius: 4px;
		font-size: 0.85em;
		font-weight: bold;
	}

	/* 處理按鈕 */
	a[href*="Edit"] {
		color: #0d6efd;
		border: 1px solid #0d6efd;
	}

		a[href*="Edit"]:hover {
			background-color: #0d6efd;
			color: white;
		}

	/* 刪除按鈕 */
	a[onclick*="confirm"] {
		color: #dc3545;
		border: 1px solid #dc3545;
	}

		a[onclick*="confirm"]:hover {
			background-color: #dc3545;
			color: white;
		}
</style>