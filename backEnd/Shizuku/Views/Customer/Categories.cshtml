@model IEnumerable<Shizuku.Wraps.CTicketCategoryWrap>

@{
    ViewData["Title"] = "問題分類管理";
}

<h1>問題分類管理</h1>

@using (Html.BeginForm())
{
    <div class="search-box p-3 bg-light rounded shadow-sm mb-3">
        <div class="row align-items-center">
            <div class="col-auto">
                <span class="fw-bold">關鍵字：</span>
                @* 對應你的 ViewModel *@
                @Html.TextBox("txtKeyword", null, new { @class = "form-control d-inline-block", style = "width:200px;", placeholder = "輸入類型或描述..." })
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-dark">查詢</button>
            </div>
        </div>
    </div>
}

<p>
    @* 如果你之前有做新增功能，這個連結就會生效 *@
    <a asp-action="CategoryCreate" class="btn btn-outline-primary mb-2">新增分類</a>
</p>

<table class="table table-hover align-middle border-bottom">
    <thead class="table-light">
        <tr>
            <th>@Html.DisplayNameFor(model => model.fName)</th>
            <th>@Html.DisplayNameFor(model => model.fDescription)</th>
            <th>建立時間</th>
            <th>管理操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">
                    @Html.DisplayFor(modelItem => item.fName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.fDescription)
                </td>
                <td class="text-muted">
                    @Html.DisplayFor(modelItem => item.Entity.FCreatedAt)
                </td>
                <td>
                    @Html.ActionLink("編輯", "CategoryEdit", "Customer", new { id = item.fId }, new { @class = "btn btn-sm btn-outline-primary" }) |
                    @Html.ActionLink("刪除", "CategoryDelete", "Customer", new { id = item.fId }, new { @class = "btn btn-sm btn-outline-danger", onclick = "return confirm('確定要刪除這筆分類嗎?')" })
                </td>
            </tr>
        }
    </tbody>
</table>