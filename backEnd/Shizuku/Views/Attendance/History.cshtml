@model Shizuku.ViewModels.AttendanceHistoryViewModel

<div class="container py-5">
    <h2 class="mb-4"><i class="bi bi-calendar3 me-2"></i>打卡紀錄查詢</h2>

    <!-- 搜尋表單卡片 -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" action="@Url.Action("History")" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">員工搜尋</label>
                    <input type="text" name="searchEmployee" value="@Model.SearchEmployee" class="form-control" placeholder="輸入編號或姓名">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">開始日期</label>
                    <input type="date" name="startDate" value="@Model.StartDate" class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">結束日期</label>
                    <input type="date" name="endDate" value="@Model.EndDate" class="form-control">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i> 搜尋
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 結果表格 -->
    <div class="table-responsive shadow-sm rounded-3 bg-white">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>日期</th>
                    <th>員編</th>
                    <th>姓名</th>
                    <th>上班</th>
                    <th>下班</th>
                    <th>狀態</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Results.Any())
                {
                    foreach (var item in Model.Results)
                    {
                        <tr>
                            <td>@item.WorkDate</td>
                            <td><span class="badge bg-light text-dark border">@item.EmployeeNumber</span></td>
                            <td class="fw-bold">@item.EmployeeName</td>
                            <td>@item.ClockInTime</td>
                            <td>@item.ClockOutTime</td>
                            <td>
                                @{
                                    string color = item.Status == "正常" ? "success" : "danger";
                                    if (item.Status.Contains("遲到") || item.Status.Contains("早退")) color = "warning";
                                }
                                <span class="badge bg-@color">@item.Status</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">查無相關紀錄</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>